{
    "manifest_version": 2,
    "name": "Password Ledger",
    "version": "1.1",
    "description": "Secure password manager with auto-fill using native messaging.",
    "permissions": [
        "nativeMessaging",
        "activeTab",
        "clipboardWrite",
        "tabs"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["content.css"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "pwledger@harun.dev",
            "strict_min_version": "109.0"
        }
    }
}